{
  "name": "@mote/editor",
  "private": true,
  "version": "0.1.1",
  "exports": {
    "./*": "./dist/*"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*"
      ]
    }
  },
  "scripts": {
