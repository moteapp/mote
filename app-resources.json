{
    "apiVersion": "apps/v1",
    "kind": "List",
    "metadata": {},
    "items": [
        {
            "apiVersion": "apps/v1",
            "kind": "Deployment",
            "metadata": {
                "name": "mote-app",
                "namespace": "mote-app"
            },
            "spec": {
                "replicas": 1,
                "selector": {
                    "matchLabels": {
                        "app": "mote-app"
                    }
                },
                "template": {
                    "metadata": {
                        "labels": {
                            "app": "mote-app"
                        }
                    },
                    "spec": {
                        "nodeSelector": {
                            "kubernetes.io/os": "linux"
                        },
                        "containers": [
                            {
                                "name": "mote-app",
                                "image": "moteapp.azurecr.io/mote/mote-app:latest",
                                "ports": [
                                    {
                                        "containerPort": 80
                                    }
                                ],
                                "resources": {
                                    "requests": {
                                        "cpu": "1m",
                                        "memory": "50Mi"
                                    },
                                    "limits": {
                                        "cpu": "75m",
                                        "memory": "128Mi"
                                    }
                                },
                                "livenessProbe": {
                                    "httpGet": {
                                        "path": "/_health",
                                        "port": 80
                                    },
                                    "initialDelaySeconds": 3,
                                    "timeoutSeconds": 1,
                                    "periodSeconds": 10,
                                    "successThreshold": 1,
                                    "failureThreshold": 3
                                }
                            }
                        ]
                    }
                }
            }
        },
        {
            "apiVersion": "v1",
            "kind": "Service",
            "metadata": {
                "name": "mote-app",
                "namespace": "mote-app"
            },
            "spec": {
                "selector": {
                    "app": "mote-app"
                },
                "ports": [
                    {
                        "port": 80,
                        "targetPort": 80
                    }
                ],
                "type": "LoadBalancer"
            }
        }
    ]
}